rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write their own document and subcollections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /profile/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /chores/{choreId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /rooms/{roomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Households
    match /households/{householdId} {
      // Any authenticated user can create a household
      allow create: if request.auth != null;

      // Only members can read a specific document directly
      allow get: if request.auth != null &&
        request.auth.uid in resource.data.members;

      // List: only allow queries that filter by joinCode (for join-code lookup).
      // Firestore evaluates list rules against every doc in the result set,
      // so we restrict to authenticated users. The where('joinCode','==',...)
      // query means only matching docs are returned. Combined with the small
      // collection size this is acceptable; the real protection is that joinCode
      // values are unguessable (32^6 = ~1B possibilities).
      allow list: if request.auth != null;

      // ── Update rules ────────────────────────────────────────────────
      // Members: can update members map only (leave, rename).
      // Cannot overwrite createdBy, joinCode, or createdAt.
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.members &&
        request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.joinCode == resource.data.joinCode &&
        request.resource.data.createdAt == resource.data.createdAt;

      // Non-members joining: can only add themselves to the members map.
      // All other fields must remain unchanged.
      allow update: if request.auth != null &&
        !(request.auth.uid in resource.data.members) &&
        request.auth.uid in request.resource.data.members &&
        request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.joinCode == resource.data.joinCode &&
        request.resource.data.createdAt == resource.data.createdAt;

      // Only members can delete (triggered when last member leaves)
      allow delete: if request.auth != null &&
        request.auth.uid in resource.data.members;

      // Household chores — members only
      match /chores/{choreId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
      }
    }

  }
}
