rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write their own document and subcollections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /profile/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /chores/{choreId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /rooms/{roomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Households
    match /households/{householdId} {
      // Any authenticated user can create a household
      allow create: if request.auth != null;

      // Only members can read a specific document directly
      allow get: if request.auth != null &&
        request.auth.uid in resource.data.members;
      // Any authenticated user can query the collection (needed to look up by join code)
      allow list: if request.auth != null;

      // Members can update (completing chores, assigning, leaving, etc.)
      // Non-members can also update to add only themselves (joining via code)
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        (request.auth.uid in request.resource.data.members &&
         !(request.auth.uid in resource.data.members))
      );

      // Only members can delete (triggered when last member leaves)
      allow delete: if request.auth != null &&
        request.auth.uid in resource.data.members;

      // Household chores — members only
      match /chores/{choreId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
      }
    }

  }
}
